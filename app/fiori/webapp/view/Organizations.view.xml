<mvc:View controllerName="lma.fiori.controller.Organizations"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:grid="sap.ui.layout.cssgrid">
    <ScrollContainer height="100%" width="100%" vertical="true" horizontal="false">
        
        <!-- Header -->
        <HBox justifyContent="SpaceBetween" alignItems="Center" wrap="Wrap" class="sapUiMediumMarginBottom">
            <VBox>
                <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                    <VBox class="adminCardHeaderIcon adminHeaderIconBlue">
                        <core:Icon xmlns:core="sap.ui.core" src="sap-icon://building" size="18px" />
                    </VBox>
                    <Title text="Organization Management" level="H1" class="bold text-2xl sapUiTinyMarginBegin" />
                </HBox>
                <Text text="Create and manage tenant organizations in your system" class="text-sm color-slate-500" />
            </VBox>
            
            <Button text="Create Organization" press=".onOpenCreateDialog" icon="sap-icon://add" type="Emphasized" class="btnPrimary sapUiTinyMarginTop" />
        </HBox>

        <grid:CSSGrid gridTemplateColumns="repeat(auto-fit, minmax(200px, 1fr))" gridGap="1rem" class="sapUiMediumMarginBottom">
            <HBox class="adminDashboardMetricCard sapUiMediumPadding" alignItems="Center">
                <VBox class="adminCardHeaderIcon sapUiMediumMarginEnd adminHeaderIconBlue">
                    <core:Icon xmlns:core="sap.ui.core" src="sap-icon://building" size="20px" />
                </VBox>
                <VBox>
                    <Text text="Total Organizations" class="bold text-xs color-slate-500 sapUiTinyMarginBottom" />
                    <Title text="{/totalOrgs}" level="H3" class="bold text-xl" />
                </VBox>
            </HBox>

            <HBox class="adminDashboardMetricCard sapUiMediumPadding" alignItems="Center">
                <VBox class="adminCardHeaderIcon sapUiMediumMarginEnd adminHeaderIconGreen">
                    <core:Icon xmlns:core="sap.ui.core" src="sap-icon://accept" size="20px" />
                </VBox>
                <VBox>
                    <Text text="Active Organizations" class="bold text-xs color-slate-500 sapUiTinyMarginBottom" />
                    <Title text="{/activeOrgs}" level="H3" class="bold text-xl" />
                </VBox>
            </HBox>

            <HBox class="adminDashboardMetricCard sapUiMediumPadding" alignItems="Center">
                <VBox class="adminCardHeaderIcon sapUiMediumMarginEnd adminHeaderIconRed">
                    <core:Icon xmlns:core="sap.ui.core" src="sap-icon://decline" size="20px" />
                </VBox>
                <VBox>
                    <Text text="Inactive Organizations" class="bold text-xs color-slate-500 sapUiTinyMarginBottom" />
                    <Title text="{/inactiveOrgs}" level="H3" class="bold text-xl" />
                </VBox>
            </HBox>
        </grid:CSSGrid>

        <!-- Search Bar -->
        <HBox class="sapUiMediumMarginBottom" alignItems="Center">
            <SearchField id="searchField" placeholder="Search organizations..." liveChange=".onSearch" width="320px" />
        </HBox>

        <!-- Grid of Organization Cards -->
        <f:GridList id="orgsGrid" items="{/filteredOrgs}" noDataText="No organizations found" class="sapUiMediumMarginBottom">
            <f:customLayout>
                <grid:GridBasicLayout gridTemplateColumns="repeat(auto-fit, minmax(280px, 1fr))" gridGap="1.5rem" />
            </f:customLayout>
            <f:GridListItem>
                <VBox class="moduleCard sapUiLargePadding">
                    <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiTinyMarginBottom">
                        <Title text="{name}" level="H3" class="bold text-lg" />
                        <ObjectStatus text="{= ${is_active} ? 'Active' : 'Inactive'}" state="{= ${is_active} ? 'Success' : 'Error'}" />
                    </HBox>
                    <Text text="Code: {code}" class="bold text-xs color-slate-500 sapUiTinyMarginBottom" />
                    
                    <VBox class="sapUiSmallMarginBottom">
                        <Text text="Email: {email}" class="text-sm color-slate-600" />
                        <Text text="Phone: {phone}" class="text-sm color-slate-600" />
                        <Text text="Trial: {trial}" class="text-sm color-slate-600" />
                    </VBox>
                    
                    <HBox justifyContent="End" class="sapUiTinyMarginTop">
                        <Button text="Edit" icon="sap-icon://edit" press=".onEditPress" type="Transparent" class="sapUiTinyMarginEnd" />
                        <Button text="Details" icon="sap-icon://navigation-right-arrow" press=".onDetailsPress" type="Emphasized" class="btnPrimary" />
                    </HBox>
                </VBox>
            </f:GridListItem>
        </f:GridList>

        <!-- CREATE / EDIT DIALOG -->
        <Dialog id="orgDialog" title="{/dialogTitle}" class="customDialog sapUiContentPadding" contentWidth="480px">
            <VBox class="sapUiSmallMargin">
                <VBox class="sapUiTinyMarginBottom">
                    <Label text="Organization Name" required="true" class="bold text-sm sapUiTinyMarginBottom" />
                    <Input id="dialogName" value="{/dialogData/name}" placeholder="e.g. Saptarishi Solutions" />
                </VBox>
                <VBox class="sapUiTinyMarginBottom">
                    <Label text="Organization Code" required="true" class="bold text-sm sapUiTinyMarginBottom" />
                    <Input id="dialogCode" value="{/dialogData/code}" placeholder="e.g. SRS" enabled="{= !${/dialogData/isEdit} }" />
                </VBox>
                <VBox class="sapUiTinyMarginBottom">
                    <Label text="Email" class="bold text-sm sapUiTinyMarginBottom" />
                    <Input id="dialogEmail" type="Email" value="{/dialogData/email}" placeholder="contact@company.com" />
                </VBox>
                <VBox class="sapUiTinyMarginBottom">
                    <Label text="Phone" class="bold text-sm sapUiTinyMarginBottom" />
                    <Input id="dialogPhone" type="Tel" value="{/dialogData/phone}" placeholder="+1 (555) 019-2834" />
                </VBox>
                <VBox class="sapUiTinyMarginBottom">
                    <Label text="Address" class="bold text-sm sapUiTinyMarginBottom" />
                    <Input id="dialogAddress" value="{/dialogData/address}" placeholder="123 Corporate Blvd" />
                </VBox>
                <VBox class="sapUiTinyMarginBottom">
                    <Label text="Country" required="true" class="bold text-sm sapUiTinyMarginBottom" />
                    <Select id="dialogCountry" items="{/countries}" change=".onCountryChange" width="100%">
                        <core:Item xmlns:core="sap.ui.core" key="{id}" text="{name}" />
                    </Select>
                </VBox>
                <VBox class="sapUiTinyMarginBottom">
                    <Label text="State" required="true" class="bold text-sm sapUiTinyMarginBottom" />
                    <Select id="dialogState" items="{/states}" width="100%">
                        <core:Item xmlns:core="sap.ui.core" key="{id}" text="{name}" />
                    </Select>
                </VBox>
                <VBox class="sapUiTinyMarginBottom">
                    <Label text="Trial Mode" required="true" class="bold text-sm sapUiTinyMarginBottom" />
                    <Select id="dialogTrial" selectedKey="{/dialogData/trial}" width="100%">
                        <core:Item xmlns:core="sap.ui.core" key="Free" text="Free Trial" />
                        <core:Item xmlns:core="sap.ui.core" key="Premium" text="Premium License" />
                    </Select>
                </VBox>
                <HBox class="sapUiSmallMarginTop" justifyContent="SpaceBetween" alignItems="Center">
                    <Label text="Organization Active" class="bold text-sm" />
                    <Switch id="dialogActive" state="{/dialogData/is_active}" />
                </HBox>
            </VBox>
            
            <beginButton>
                <Button text="Save" type="Emphasized" press=".onSaveOrganization" />
            </beginButton>
            <endButton>
                <Button text="Cancel" press=".onCloseDialog" />
            </endButton>
        </Dialog>

    </ScrollContainer>
</mvc:View>
