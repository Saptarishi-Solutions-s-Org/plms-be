{
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "typeRoots": ["srv/types", "./node_modules/@types"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "target": "ES2020",
    "outDir": "dist",
    "rootDir": ".",
    "declaration": false
  },
  "include": ["srv", "srv/types"]
}
