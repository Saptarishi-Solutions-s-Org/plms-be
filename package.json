{
  "name": "plms-be",
  "version": "1.0.0",
  "description": "CAP Backend",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "start": "cds-ts serve",
    "watch": "cds-ts watch",
    "dev": "cds-ts watch"
  },
  "dependencies": {
    "@cap-js/postgres": "^2.2.0",
    "@sap/cds": "^9.8.4",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "resend": "^6.10.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.2.0",
    "@sap/cds-dk": "^9.8.3",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.20.0",
    "@types/socket.io": "^3.0.1",
    "cds-plugin-ui5": "^0.16.3",
    "dotenv": "^17.4.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "cds": {
    "build": {
      "clean": false
    },
    "requires": {
      "auth": {
        "kind": "mocked"
      },
      "db": {
        "kind": "postgres",
        "credentials": {
          "url": "${DATABASE_URL}"
        },
        "impl": "@cap-js/postgres",
        "schema_evolution": "off"
      }
    }
  },
  "main": "deploy.js",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Saptarishi-Solutions-s-Org/plms-be/issues"
  },
  "homepage": "https://github.com/Saptarishi-Solutions-s-Org/plms-be#readme"
}